DATABASE_URL=postgresql://admin:adminpassword@localhost:5432/tender_rag
SECRET_KEY=your-super-secret-development-key

REDIS_URL=redis://localhost:6379/0

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tender-documents
MINIO_SECURE=false

QDRANT_HOST=localhost
QDRANT_PORT=6333

PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# OCR backend:
#   gemini    — best quality, uses GEMINI_API_KEY, 1 call/page
#   easyocr   — local GPU (default)
#   tesseract — local CPU, needs: apt-get install tesseract-ocr tesseract-ocr-hin
OCR_ENGINE=gemini

LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
RAG_TOP_K=5
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

#celery -A celery_worker worker --loglevel=info