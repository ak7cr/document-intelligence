# ── Copy this file to .env and fill in your values ──────────────────────────
# cp .env.example .env   (Linux/Mac)
# copy .env.example .env  (Windows)

# LLM provider — choose one:
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# For offline use with Ollama (install from https://ollama.com, run: ollama pull qwen2:7b)
# LLM_PROVIDER=ollama
# OLLAMA_HOST=http://host.docker.internal:11434
# OLLAMA_MODEL=qwen2:7b

# OCR engine: gemini (best), easyocr (local GPU), tesseract (CPU, no GPU needed)
OCR_ENGINE=gemini

# These are set automatically by docker-compose — do not change:
# DATABASE_URL, REDIS_URL, MINIO_ENDPOINT, QDRANT_HOST

# MinIO credentials (can leave as-is for local use)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tender-documents

SECRET_KEY=change-this-to-a-random-string
